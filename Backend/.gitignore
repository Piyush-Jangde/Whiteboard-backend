# A git ignore file for Node js Project, that also ignores .DS_Store in every subfolder# Dependencies
node_modules/

# Environment variables
.env
.env.*
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime files
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/

# Build output
dist/
build/

# Cache
.cache/
.parcel-cache/

# OS files
.DS_Store
**/.DS_Store
Thumbs.db

# IDE/editor files
.vscode/
.idea/
*.swp
*.swo

# Optional package manager lock files
# Uncomment if you don't want to track these
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Temporary files
tmp/
temp/

# Misc
*.bak
*.orig